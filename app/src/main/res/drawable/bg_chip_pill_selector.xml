<?xml version="1.0" encoding="utf-8"?>
<!-- Tab Pill 状态选择器: 选中=brand 未选中=透明(hover state list ripple 处理) -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true" android:drawable="@drawable/bg_chip_active" />
    <item android:state_selected="true" android:drawable="@drawable/bg_chip_active" />
    <item android:state_pressed="true" android:drawable="@drawable/bg_chip_inactive" />
    <item android:drawable="@drawable/bg_chip_inactive" />
</selector>
