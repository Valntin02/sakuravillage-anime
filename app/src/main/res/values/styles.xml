<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ==========================================================
         主题样式 — 与 frontend (Vue + Tailwind + Element-Plus) 视觉一致
         核心: 极光蓝 brand 500 / 深色 0A0E14 / 软边框 white/5 / 圆角 16dp
         ========================================================== -->

    <!-- ====== 应用主主题 ====== -->
    <style name="AppTheme" parent="Theme.MaterialComponents.NoActionBar">
        <!-- 核心颜色 -->
        <item name="colorPrimary">@color/brand_500</item>
        <item name="colorPrimaryDark">@color/brand_700</item>
        <item name="colorAccent">@color/brand_500</item>
        <item name="colorSecondary">@color/accent_500</item>
        <item name="colorOnPrimary">@color/text_on_brand</item>

        <!-- 背景颜色 -->
        <item name="android:windowBackground">@color/dark_bg</item>
        <item name="android:colorBackground">@color/dark_bg</item>

        <!-- 文本颜色 -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorTertiary">@color/text_tertiary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>

        <!-- 状态栏 / 导航栏 (深色沉浸式) -->
        <item name="android:statusBarColor">@color/dark_bg</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:navigationBarColor">@color/dark_bg</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>

        <!-- 对话框主题 (经典 AlertDialog；MaterialAlertDialog 单独由调用方注入 overlay) -->
        <item name="alertDialogTheme">@style/AlertDialogCustom</item>
    </style>

    <!-- ====== Glass-Nav 顶部栏 (frontend .glass-nav) ====== -->
    <style name="GlassAppBar">
        <item name="android:background">@drawable/bg_glass_nav</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- ====== 底部导航栏 ====== -->
    <style name="BottomNavTheme" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/nav_bg</item>
        <item name="itemBackground">@color/transparent</item>
        <item name="itemIconTint">@color/bottom_nav_item_color</item>
        <item name="itemTextColor">@color/bottom_nav_item_color</item>
        <item name="itemRippleColor">@color/brand_500_alpha15</item>
        <item name="elevation">0dp</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>

    <!-- ====== 卡片样式 ====== -->
    <!-- 默认卡 (frontend: bg-dark-card border border-white/5 rounded-2xl) -->
    <style name="CardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/dark_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/border_soft</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- 软卡 (列表内 / 紧凑场景, 12dp 圆角) -->
    <style name="SoftCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/dark_card</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/border_soft</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- 大圆角卡 (Hero / Profile, 24dp) -->
    <style name="LargeCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/dark_card</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/border_soft</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- 带品牌色阴影的强调卡 -->
    <style name="BrandShadowCard" parent="CardStyle">
        <item name="cardElevation">8dp</item>
        <item name="android:outlineSpotShadowColor" tools:targetApi="p">@color/brand_500</item>
        <item name="android:outlineAmbientShadowColor" tools:targetApi="p">@color/brand_500</item>
    </style>

    <!-- ====== 按钮样式 ====== -->
    <!-- 主按钮 (frontend: bg-brand-500 hover:bg-brand-600 shadow-brand-500/20) -->
    <style name="PrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/brand_500</item>
        <item name="android:textColor">@color/text_on_brand</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="rippleColor">@color/overlay_white_20</item>
        <item name="android:elevation" tools:targetApi="lollipop">4dp</item>
        <item name="android:outlineSpotShadowColor" tools:targetApi="p">@color/brand_500</item>
    </style>

    <!-- 圆角胶囊主按钮 (frontend 登录按钮: rounded-full) -->
    <style name="PillButton" parent="PrimaryButton">
        <item name="cornerRadius">999dp</item>
        <item name="android:paddingLeft">20dp</item>
        <item name="android:paddingRight">20dp</item>
        <item name="android:minHeight">36dp</item>
    </style>

    <style name="OutlinedButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/brand_500</item>
        <item name="android:textColor">@color/brand_500</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="rippleColor">@color/brand_500_alpha15</item>
    </style>

    <style name="OutlinedPillButton" parent="OutlinedButton">
        <item name="cornerRadius">999dp</item>
    </style>

    <style name="TextButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/brand_500</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">48dp</item>
        <item name="rippleColor">@color/brand_500_alpha15</item>
    </style>

    <!-- 危险按钮 -->
    <style name="DangerButton" parent="PrimaryButton">
        <item name="backgroundTint">@color/error</item>
    </style>

    <!-- ====== 编辑框 ====== -->
    <style name="EditTextStyle" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/dark_card</item>
        <item name="boxStrokeColor">@color/border_soft</item>
        <item name="boxStrokeErrorColor">@color/error</item>
        <item name="hintTextColor">@color/text_tertiary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
    </style>

    <!-- ====== Tab Pill (frontend: 活动 tab `bg-brand-500 shadow-brand-500/20`) ====== -->
    <style name="TabPill">
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:paddingLeft">14dp</item>
        <item name="android:paddingRight">14dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:background">@drawable/bg_chip_inactive</item>
    </style>

    <style name="TabPillSelected" parent="TabPill">
        <item name="android:textColor">@color/text_on_brand</item>
        <item name="android:background">@drawable/bg_chip_active</item>
    </style>

    <!-- ====== 文本样式 ====== -->
    <style name="TextHeading">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextSubheading">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextBody">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextCaption">
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:textSize">12sp</item>
    </style>

    <!-- 渐变品牌标题 (frontend .text-gradient brand→purple) -->
    <style name="TextGradientBrand" parent="TextHeading">
        <item name="android:background">@drawable/bg_text_gradient_brand</item>
    </style>

    <!-- ====== Profile 专用 (兼容现有 fragment_profile.xml) ====== -->
    <style name="ProfileSurfaceCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface_1</item>
        <item name="cardCornerRadius">22dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/border_subtle</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="ProfileMetricCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface_2</item>
        <item name="cardCornerRadius">18dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/border_subtle</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="ProfileGlassCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/glass_surface</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/glass_border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="ProfileGlassCardStrong" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/glass_surface_strong</item>
        <item name="cardCornerRadius">22dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/glass_border_subtle</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="ProfileTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ProfileSectionTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ProfileMetricValue">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ProfileMetricLabel">
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="ProfileActionTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ProfileActionBody">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="ProfileHeroEyebrow">
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <style name="ProfileHeroTitle">
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">30sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ProfileHeroBody">
        <item name="android:textColor">@color/text_on_hero_secondary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:lineSpacingExtra">3dp</item>
    </style>

    <!-- ====== 对话框 ====== -->
    <style name="AlertDialogCustom" parent="Theme.MaterialComponents.Dialog.Alert">
        <item name="colorPrimary">@color/brand_500</item>
        <item name="colorAccent">@color/brand_500</item>
        <item name="android:background">@color/dark_card</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="buttonBarPositiveButtonStyle">@style/AlertDialogButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/AlertDialogButton</item>
    </style>

    <style name="AlertDialogTitle" parent="MaterialAlertDialog.MaterialComponents.Title.Text">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AlertDialogBody" parent="MaterialAlertDialog.MaterialComponents.Body.Text">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="AlertDialogButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/brand_500</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- ====== 兼容历史风格 ====== -->
    <style name="Theme.AppCompat.Translucent" parent="AppTheme">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:windowDisablePreview">true</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.AppCompat.Transitions" parent="AppTheme">
        <item name="android:windowContentTransitions">true</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.AppCompat.Full" parent="Theme.AppCompat.Translucent">
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="dialog_style" parent="@android:style/Theme.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <style name="AppTheme.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />
    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <!-- ====== 通用形状 / 文本 ====== -->
    <style name="CircularShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="BottomNavTextAppearance" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:paddingTop">15dp</item>
        <item name="android:textSize">12sp</item>
    </style>

</resources>
